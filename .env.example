# Application (for local/XAMPP: use APP_URL=http://localhost/khbeventsboothsystemkmall)
APP_NAME="KHB Booths Booking System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

APP_KEY=

# Database
# Option A: Local MySQL (LAMPP/XAMPP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khbevents_aebooths
DB_USERNAME=root
DB_PASSWORD=

# Option B: Live cPanel DB from local (set DB_CONNECTION=mysql_remote, enable Remote MySQL in cPanel)
# DB_CONNECTION=mysql_remote
# REMOTE_DB_HOST=your-domain.com
# REMOTE_DB_PORT=3306
# REMOTE_DB_DATABASE=your_db_name
# REMOTE_DB_USERNAME=your_db_user
# REMOTE_DB_PASSWORD=your_db_password

# For storage:pull - pull images/assets from cPanel
# REMOTE_FTP_HOST=your-domain.com
# REMOTE_FTP_USER=your_cpanel_username
# REMOTE_FTP_PASSWORD=your_password
# REMOTE_FTP_PATH=/home/username/domain.com
# For rsync (if SSH available): REMOTE_SSH_HOST, REMOTE_SSH_USER, REMOTE_RSYNC_PATH=~/domain.com

# GitHub Configuration
# Copy this file to .env and fill in your GitHub credentials

# GitHub Username
GITHUB_USERNAME=your_github_username

# GitHub Personal Access Token (PAT)
# Generate one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=your_github_personal_access_token

# GitHub Repository URL (optional - will use remote if not set)
GITHUB_REPO_URL=https://github.com/chamnabmeyinfo/khbevents-boothsystem-kmall.git

# Use SSH instead of HTTPS (true/false)
# If true, you need to set up SSH keys instead of using token
GITHUB_USE_SSH=false

# Telegram Bot (Activity Notifications)
# Create a bot via @BotFather, add it to a group/channel, then get chat ID from getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ACTIVITY_ENABLED=true

# Push Notifications (Web Push / VAPID)
# Enable/disable and VAPID public key can also be set in Settings > Push Notifications (DB overrides these when set).
# PUSH_NOTIFICATIONS_ENABLED=true
# PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
# PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
